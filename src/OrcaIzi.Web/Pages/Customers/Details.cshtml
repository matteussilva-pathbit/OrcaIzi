@page "{id:Guid}"
@model OrcaIzi.Web.Pages.Customers.DetailsModel
@{
    ViewData["Title"] = "Detalhes do Cliente";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
            <div class="mb-3 mb-md-0">
                <h2 class="fw-bold mb-1">Detalhes do Cliente</h2>
                <p class="text-muted mb-0">Visualize as informações cadastrais</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-page="Index" class="btn btn-light rounded-pill px-3">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
                <a asp-page="Edit" asp-route-id="@Model.Customer.Id" class="btn btn-primary rounded-pill px-3 shadow-sm">
                    <i class="bi bi-pencil me-2"></i> Editar
                </a>
            </div>
        </div>

        <div class="card shadow-lg border-0 overflow-hidden">
            <div class="card-body p-5">
                <div class="text-center mb-5">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3 fw-bold shadow-sm" style="width: 80px; height: 80px; font-size: 2rem;">
                        @Model.Customer.Name.Substring(0, 1).ToUpper()
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Customer.Name</h3>
                    <p class="text-muted mb-0">Cliente Cadastrado</p>
                </div>

                <div class="row g-4 justify-content-center">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3 h-100">
                            <label class="text-uppercase text-muted small fw-bold mb-2">Email</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-envelope text-primary me-2"></i>
                                <span class="fw-medium text-dark">@Model.Customer.Email</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3 h-100">
                            <label class="text-uppercase text-muted small fw-bold mb-2">Telefone</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-telephone text-primary me-2"></i>
                                <span class="fw-medium text-dark">@Model.Customer.Phone</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3 h-100">
                            <label class="text-uppercase text-muted small fw-bold mb-2">Documento (CPF/CNPJ)</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-person-vcard text-primary me-2"></i>
                                <span class="fw-medium text-dark">@Model.Customer.Document</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3 h-100">
                            <label class="text-uppercase text-muted small fw-bold mb-2">Endereço</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-geo-alt text-primary me-2"></i>
                                <span class="fw-medium text-dark">@Model.Customer.Address</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top text-center">
                    <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Customer.Id" onsubmit="return confirm('Tem certeza que deseja excluir este cliente? Esta ação não pode ser desfeita.');">
                        <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
                            <i class="bi bi-trash me-2"></i> Excluir Cliente
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
