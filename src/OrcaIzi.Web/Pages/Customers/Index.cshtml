@page
@model OrcaIzi.Web.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5">
    <div>
        <h1 class="fw-bold mb-1">Clientes</h1>
        <p class="text-muted mb-0">Gerencie sua base de contatos</p>
    </div>
    <a asp-page="Create" class="btn btn-primary rounded-pill px-4 mt-3 mt-md-0 shadow-sm">
        <i class="bi bi-person-plus me-2"></i> Novo Cliente
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase text-muted small fw-bold border-0">Nome</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Email</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Telefone</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Documento</th>
                        <th class="pe-4 py-3 text-end text-uppercase text-muted small fw-bold border-0">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Customers.Items != null && Model.Customers.Items.Any())
                    {
                        @foreach (var item in Model.Customers.Items)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 40px; height: 40px;">
                                            @item.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-medium text-dark">@item.Name</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted">@item.Email</td>
                                <td class="text-muted">@item.Phone</td>
                                <td class="text-muted">@item.Document</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-muted" title="Detalhes">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-muted" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir este cliente?');">
                                            <button type="submit" class="btn btn-sm btn-light text-danger" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="py-5">
                                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                                        <i class="bi bi-people text-muted fs-2"></i>
                                    </div>
                                    <h5 class="text-muted mb-1">Nenhum cliente encontrado</h5>
                                    <p class="text-muted small mb-3">Adicione seus clientes para começar.</p>
                                    <a asp-page="Create" class="btn btn-outline-primary btn-sm rounded-pill">
                                        Adicionar Cliente
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    @if (Model.Customers.TotalCount > Model.PageSize)
    {
        <div class="card-footer bg-white border-top-0 py-3">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(Model.Customers.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link border-0 text-muted" asp-route-PageNumber="@(Model.Customers.PageNumber - 1)">Anterior</a>
                    </li>
                    
                    @{
                        var totalPages = (int)Math.Ceiling((double)Model.Customers.TotalCount / Model.PageSize);
                        for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == Model.Customers.PageNumber ? "active" : "")">
                                <a class="page-link border-0 rounded-circle mx-1 @(i == Model.Customers.PageNumber ? "bg-primary text-white" : "text-muted")" 
                                   style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;"
                                   asp-route-PageNumber="@i">@i</a>
                            </li>
                        }
                    }
                    
                    <li class="page-item @(Model.Customers.PageNumber == totalPages ? "disabled" : "")">
                        <a class="page-link border-0 text-muted" asp-route-PageNumber="@(Model.Customers.PageNumber + 1)">Próximo</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
