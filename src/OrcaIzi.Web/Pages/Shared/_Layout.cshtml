<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OrcaIzi</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile-fixes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OrcaIzi.Web.styles.css" asp-append-version="true" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark fixed-top">
            <div class="container-fluid px-5">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-page="/Index">
                    <img src="~/images/logo.png" alt="OrcaIzi" style="height: 80px; width: auto;" />
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav mb-2 mb-lg-0 gap-4 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Budgets/Index">Orçamentos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/BudgetTemplates/Index">Templates</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Tools/Index">Ferramentas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Customers/Index">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-uppercase fw-bold mx-2" asp-page="/Account/Profile" style="font-size: 0.9rem; letter-spacing: 1px;">Perfil</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-uppercase fw-bold mx-2 text-danger" asp-page="/Account/Logout" style="font-size: 0.9rem; letter-spacing: 1px;">Sair</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-link text-decoration-none" asp-area="" asp-page="/Account/Login">LOGIN</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary px-4" asp-area="" asp-page="/Account/Register">COMEÇAR</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="@(ViewData["FullWidth"] as bool? == true ? "w-100 p-0" : "container mt-5 pt-5") flex-grow-1" style="padding-top: 100px !important;">
        <main role="main" class="pb-3 animate-fade-in">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-4">
        <div class="container text-center">
            <div class="d-flex flex-column align-items-center justify-content-center">
                <img src="~/images/logo.png" alt="OrcaIzi" class="mb-3" style="height: 70px; width: auto; opacity: 0.8;" />
                <p class="text-muted small mb-0">
                    &copy; 2026 OrcaIzi. Todos os direitos reservados.
                </p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
            // Check for success message
            @if (TempData["Success"] != null)
            {
                <text>
                Swal.fire({
                    title: 'Sucesso!',
                    text: '@Html.Raw(TempData["Success"])',
                    icon: 'success',
                    background: '#111',
                    color: '#fff',
                    confirmButtonColor: '#FFD700',
                    confirmButtonText: 'OK',
                    timer: 3000,
                    timerProgressBar: true
                });
                </text>
            }

            // Check for error message
            @if (TempData["Error"] != null)
            {
                <text>
                Swal.fire({
                    title: 'Erro!',
                    text: '@Html.Raw(TempData["Error"])',
                    icon: 'error',
                    background: '#111',
                    color: '#fff',
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'OK'
                });
                </text>
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
