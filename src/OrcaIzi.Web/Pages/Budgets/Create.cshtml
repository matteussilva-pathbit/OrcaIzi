@page
@model OrcaIzi.Web.Pages.Budgets.CreateModel
@{
    ViewData["Title"] = "Novo Orçamento";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">Novo Orçamento</h2>
                <p class="text-muted mb-0">Preencha os dados para criar uma nova proposta</p>
            </div>
            <a asp-page="Index" class="btn btn-light rounded-pill px-4 text-muted">
                <i class="bi bi-arrow-left me-2"></i> Voltar
            </a>
        </div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        
        <div class="row">
            <div class="col-md-8 mb-3">
                <label asp-for="Budget.Title" class="form-label">Título do Orçamento</label>
                <input asp-for="Budget.Title" class="form-control" placeholder="Ex: Reforma da Cozinha" style="background-color: #000 !important; color: #fff !important;" />
                <span asp-validation-for="Budget.Title" class="text-danger"></span>
            </div>
            
            <div class="col-md-4 mb-3">
                <label asp-for="Budget.CustomerId" class="form-label">Cliente</label>
                <select asp-for="Budget.CustomerId" asp-items="Model.Customers" class="form-select" style="background-color: #000 !important; color: #fff !important;">
                    <option value="">Selecione um cliente...</option>
                </select>
                <span asp-validation-for="Budget.CustomerId" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Budget.Description" class="form-label">Descrição Detalhada</label>
            <textarea asp-for="Budget.Description" class="form-control" rows="3" style="background-color: #000 !important; color: #fff !important;"></textarea>
            <span asp-validation-for="Budget.Description" class="text-danger"></span>
        </div>

        <div class="row mb-3">
            <div class="col-md-4">
                <label asp-for="Budget.ExpirationDate" class="form-label">Válido Até</label>
                <input asp-for="Budget.ExpirationDate" class="form-control" type="date" style="background-color: #000 !important; color: #fff !important;" />
                <span asp-validation-for="Budget.ExpirationDate" class="text-danger"></span>
            </div>
            <div class="col-md-8">
                <label asp-for="Budget.Observations" class="form-label">Observações</label>
                <input asp-for="Budget.Observations" class="form-control" style="background-color: #000 !important; color: #fff !important;" />
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
            <h4 class="mb-0">Itens do Orçamento</h4>
            <div class="d-flex gap-2">
                <button type="button" id="addFromCatalogBtn" class="btn btn-outline-secondary btn-sm rounded-pill">
                    <i class="bi bi-collection me-2"></i> Do Catálogo
                </button>
                <button type="button" id="addItemBtn" class="btn btn-outline-primary btn-sm rounded-pill">
                    <i class="bi bi-plus-lg me-2"></i> Adicionar Item
                </button>
            </div>
        </div>
        
        <div id="budget-items">
            @for (int i = 0; i < Model.Budget.Items.Count; i++)
            {
                <div class="card mb-3 budget-item bg-dark border-secondary">
                    <div class="card-body">
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn-close btn-close-white remove-item" aria-label="Remover"></button>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-2">
                                <label class="form-label text-white">Item</label>
                                <input asp-for="Budget.Items[i].Name" class="form-control" style="background-color: #000 !important; color: #fff !important;" />
                                <span asp-validation-for="Budget.Items[i].Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-2">
                                <label class="form-label text-white">Descrição</label>
                                <input asp-for="Budget.Items[i].Description" class="form-control" style="background-color: #000 !important; color: #fff !important;" />
                            </div>
                            <div class="col-md-2 mb-2">
                                <label class="form-label text-white">Qtd</label>
                                <input asp-for="Budget.Items[i].Quantity" class="form-control item-quantity" type="number" min="1" style="background-color: #000 !important; color: #fff !important;" />
                            </div>
                            <div class="col-md-2 mb-2">
                                <label class="form-label text-white">Valor Unit.</label>
                                <input asp-for="Budget.Items[i].UnitPrice" asp-format="{0:N2}" class="form-control item-price money" type="text" style="background-color: #000 !important; color: #fff !important;" />
                                <span asp-validation-for="Budget.Items[i].UnitPrice" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        
        <div class="d-grid gap-2 mt-4">
            <button type="submit" class="btn btn-primary btn-lg">SALVAR ORÇAMENTO</button>
        </div>
    </form>
    </div>
</div>

<div class="modal fade" id="catalogModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content bg-dark text-white border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">Adicionar do Catálogo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input id="catalogSearchInput" class="form-control" placeholder="Buscar por nome ou categoria..." style="background-color: #000 !important; color: #fff !important;" />
                    <button type="button" id="catalogSearchBtn" class="btn btn-outline-primary">Buscar</button>
                </div>

                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Categoria</th>
                                <th class="text-end">Valor</th>
                                <th class="text-end">Ação</th>
                            </tr>
                        </thead>
                        <tbody id="catalogResultsBody"></tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <a asp-page="/CatalogItems/Index" target="_blank" class="btn btn-outline-secondary btn-sm rounded-pill">Gerenciar Catálogo</a>
                    <div class="small text-muted" id="catalogResultsInfo"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script>
        // Override jQuery validation methods to support comma as decimal separator
        $.validator.methods.number = function (value, element) {
            return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:\.\d{3})+)(?:,\d+)?$/.test(value);
        }
        $.validator.methods.range = function (value, element, param) {
            var globalizedValue = value.replace(".", "").replace(",", ".");
            return this.optional(element) || (globalizedValue >= param[0] && globalizedValue <= param[1]);
        }
        
        $(document).ready(function () {
            // Apply mask to existing items
            $('.money').mask('000.000.000.000.000,00', {reverse: true});

            // Prevent form submission on Enter
            $(window).keydown(function(event){
                if(event.keyCode == 13) {
                    event.preventDefault();
                    return false;
                }
            });

            // Fix form submission
            $('form').submit(function(e) {
                // Unmask money fields before validation to ensure they are treated as numbers
                // OR ensure validation handles the mask. 
                // The current validation override handles comma.
                // However, the model binder might fail if it receives "49,90" and expects a decimal in a JSON post if not configured correctly.
                // But this is a form post, so it sends key-value pairs. 
                // ASP.NET Core Model Binding uses the current culture. 
                // We set pt-BR culture in Program.cs so it should work.
                
                if (!$(this).valid()) {
                    console.log("Form is invalid");
                    var validator = $(this).validate();
                    for (var i in validator.errorMap) {
                      console.log(i, ":", validator.errorMap[i]);
                    }
                    return false;
                }
                console.log("Form is valid, submitting...");
                return true;
            });

            let itemIndex = @Model.Budget.Items.Count;

            function addItemRow(initial) {
                const currentIndex = itemIndex;
                const template = `
                <div class="card mb-3 budget-item bg-dark border-secondary">
                    <div class="card-body">
                        <div class="d-flex justify-content-end mb-2">
                            <button type="button" class="btn-close btn-close-white remove-item" aria-label="Remover"></button>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-2">
                                <label class="form-label text-white">Item</label>
                                <input name="Budget.Items[${currentIndex}].Name" class="form-control" placeholder="Nome do Item" required style="background-color: #000 !important; color: #fff !important;" />
                                <span class="text-danger field-validation-valid" data-valmsg-for="Budget.Items[${currentIndex}].Name" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-md-4 mb-2">
                                <label class="form-label text-white">Descrição</label>
                                <input name="Budget.Items[${currentIndex}].Description" class="form-control" placeholder="Descrição opcional" style="background-color: #000 !important; color: #fff !important;" />
                            </div>
                            <div class="col-md-2 mb-2">
                                <label class="form-label text-white">Qtd</label>
                                <input type="number" name="Budget.Items[${currentIndex}].Quantity" class="form-control item-quantity" value="1" min="1" required style="background-color: #000 !important; color: #fff !important;" />
                            </div>
                            <div class="col-md-2 mb-2">
                                <label class="form-label text-white">Valor Unit.</label>
                                <input type="text" name="Budget.Items[${currentIndex}].UnitPrice" class="form-control item-price money" value="0,00" required style="background-color: #000 !important; color: #fff !important;" />
                                <span class="text-danger field-validation-valid" data-valmsg-for="Budget.Items[${currentIndex}].UnitPrice" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>
                </div>`;
                
                $('#budget-items').append(template);
                $('.money').mask('000.000.000.000.000,00', {reverse: true});

                if (initial) {
                    const name = initial.name ?? initial.Name ?? '';
                    const description = initial.description ?? initial.Description ?? '';
                    const unitPrice = initial.unitPrice ?? initial.UnitPrice ?? 0;

                    $(`input[name="Budget.Items[${currentIndex}].Name"]`).val(name);
                    $(`input[name="Budget.Items[${currentIndex}].Description"]`).val(description);
                    $(`input[name="Budget.Items[${currentIndex}].UnitPrice"]`).val(Number(unitPrice).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
                }

                itemIndex++;
            }

            $('#addItemBtn').click(function () {
                addItemRow();
            });

            const catalogModalEl = document.getElementById('catalogModal');
            const catalogModal = new bootstrap.Modal(catalogModalEl);
            const catalogUrl = '@Url.Page(null, "CatalogItems")';

            function renderCatalog(items) {
                const $tbody = $('#catalogResultsBody');
                $tbody.empty();

                if (!items || items.length === 0) {
                    $tbody.append(`<tr><td colspan="4" class="text-center text-muted py-4">Nenhum item encontrado</td></tr>`);
                    return;
                }

                for (const it of items) {
                    const id = it.id ?? it.Id;
                    const name = it.name ?? it.Name ?? '';
                    const category = it.category ?? it.Category ?? '';
                    const unitPrice = it.unitPrice ?? it.UnitPrice ?? 0;
                    const priceText = Number(unitPrice).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                    const row = `
                        <tr>
                            <td>${$('<div>').text(name).html()}</td>
                            <td class="text-muted">${$('<div>').text(category).html()}</td>
                            <td class="text-end">R$ ${priceText}</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-primary rounded-pill catalog-add" data-id="${id}">Adicionar</button>
                            </td>
                        </tr>`;
                    $tbody.append(row);
                }
            }

            async function loadCatalog() {
                const q = $('#catalogSearchInput').val() || '';
                $('#catalogResultsInfo').text('Carregando...');
                const res = await fetch(`${catalogUrl}&q=${encodeURIComponent(q)}`);
                const json = await res.json();
                const items = json.items ?? json.Items ?? [];
                renderCatalog(items);
                $('#catalogResultsInfo').text(`${items.length} item(ns)`);
            }

            $('#addFromCatalogBtn').click(async function () {
                $('#catalogSearchInput').val('');
                await loadCatalog();
                catalogModal.show();
            });

            $('#catalogSearchBtn').click(async function () {
                await loadCatalog();
            });

            $('#catalogSearchInput').on('input', function () {
                clearTimeout(window.__catalogTimer);
                window.__catalogTimer = setTimeout(loadCatalog, 250);
            });

            $(document).on('click', '.catalog-add', async function () {
                const id = $(this).data('id');
                const q = $('#catalogSearchInput').val() || '';
                const res = await fetch(`${catalogUrl}&q=${encodeURIComponent(q)}`);
                const json = await res.json();
                const items = json.items ?? json.Items ?? [];
                const selected = items.find(x => (x.id ?? x.Id) === id);
                if (selected) {
                    addItemRow(selected);
                    catalogModal.hide();
                }
            });

            $(document).on('click', '.remove-item', function () {
                $(this).closest('.budget-item').remove();
                reindexItems();
            });

            function reindexItems() {
                $('#budget-items .budget-item').each(function (index) {
                    $(this).find('input').each(function () {
                        if (this.name) {
                            this.name = this.name.replace(/Items\[\d+\]/, `Items[${index}]`);
                        }
                    });
                    $(this).find('span[data-valmsg-for]').each(function () {
                        const name = $(this).attr('data-valmsg-for');
                        if (name) {
                            $(this).attr('data-valmsg-for', name.replace(/Items\[\d+\]/, `Items[${index}]`));
                        }
                    });
                });
                itemIndex = $('#budget-items .budget-item').length;
            }
        });
    </script>
}
