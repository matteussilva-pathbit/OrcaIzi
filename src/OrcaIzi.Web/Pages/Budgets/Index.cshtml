@page
@model OrcaIzi.Web.Pages.Budgets.IndexModel
@{
    ViewData["Title"] = "Orçamentos";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5">
    <div>
        <h1 class="fw-bold mb-1">Orçamentos</h1>
        <p class="text-muted mb-0">Gerencie suas propostas e acompanhe status</p>
    </div>
    <a asp-page="Create" class="btn btn-primary rounded-pill px-4 mt-3 mt-md-0 shadow-sm">
        <i class="bi bi-plus-lg me-2"></i> Novo Orçamento
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase text-muted small fw-bold border-0">Título</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Cliente</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Status</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Total</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Vencimento</th>
                        <th class="pe-4 py-3 text-end text-uppercase text-muted small fw-bold border-0">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Budgets.Items != null && Model.Budgets.Items.Any())
                    {
                        @foreach (var item in Model.Budgets.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-medium text-dark">@item.Title</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center text-muted me-2" style="width: 32px; height: 32px;">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <span>@item.CustomerName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-opacity-10 text-uppercase px-3 py-2
                                        @(item.Status.ToString() == "Paid" ? "bg-success text-success" :
                                          item.Status.ToString() == "Approved" ? "bg-primary text-primary" :
                                          item.Status.ToString() == "Rejected" ? "bg-danger text-danger" :
                                          item.Status.ToString() == "Sent" ? "bg-warning text-warning" :
                                          item.Status.ToString() == "Cancelled" ? "bg-dark text-dark" :
                                          "bg-secondary text-secondary")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="fw-bold text-dark">@item.TotalAmount.ToString("C2")</td>
                                <td class="text-muted">@item.ExpirationDate.ToShortDateString()</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-muted" title="Detalhes">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form method="post" asp-page-handler="ExportPdf" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light text-danger" title="PDF">
                                                <i class="bi bi-file-earmark-pdf"></i>
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="Duplicate" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light text-primary" title="Duplicar">
                                                <i class="bi bi-copy"></i>
                                            </button>
                                        </form>
                                        @if (!string.IsNullOrEmpty(item.WhatsAppLink))
                                        {
                                            <a href="@item.WhatsAppLink" target="_blank" class="btn btn-sm btn-light text-success" title="WhatsApp">
                                                <i class="bi bi-whatsapp"></i>
                                            </a>
                                        }
                                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-muted" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir este orçamento?');">
                                            <button type="submit" class="btn btn-sm btn-light text-danger" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="py-5">
                                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                                        <i class="bi bi-file-earmark-text text-muted fs-2"></i>
                                    </div>
                                    <h5 class="text-muted mb-1">Nenhum orçamento encontrado</h5>
                                    <p class="text-muted small mb-3">Comece criando seu primeiro orçamento.</p>
                                    <a asp-page="Create" class="btn btn-outline-primary btn-sm rounded-pill">
                                        Criar Orçamento
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    @if (Model.Budgets.TotalCount > Model.PageSize)
    {
        <div class="card-footer bg-white border-top-0 py-3">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(Model.Budgets.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link border-0 text-muted" asp-route-PageNumber="@(Model.Budgets.PageNumber - 1)">Anterior</a>
                    </li>
                    
                    @{
                        var totalPages = (int)Math.Ceiling((double)Model.Budgets.TotalCount / Model.PageSize);
                        for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == Model.Budgets.PageNumber ? "active" : "")">
                                <a class="page-link border-0 rounded-circle mx-1 @(i == Model.Budgets.PageNumber ? "bg-primary text-white" : "text-muted")" 
                                   style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;"
                                   asp-route-PageNumber="@i">@i</a>
                            </li>
                        }
                    }
                    
                    <li class="page-item @(Model.Budgets.PageNumber == totalPages ? "disabled" : "")">
                        <a class="page-link border-0 text-muted" asp-route-PageNumber="@(Model.Budgets.PageNumber + 1)">Próximo</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
