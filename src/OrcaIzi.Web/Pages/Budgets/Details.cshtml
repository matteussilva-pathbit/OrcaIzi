@page "{id:Guid}"
@model OrcaIzi.Web.Pages.Budgets.DetailsModel
@{
    ViewData["Title"] = "Detalhes do Orçamento";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
            <div class="mb-3 mb-md-0">
                <h2 class="fw-bold mb-1">Detalhes do Orçamento</h2>
                <p class="text-muted mb-0">Visualize as informações completas</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-page="Index" class="btn btn-light rounded-pill px-3">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
                <form method="post" asp-page-handler="ExportPdf" asp-route-id="@Model.Budget.Id" class="d-inline">
                    <button type="submit" class="btn btn-danger rounded-pill px-3 shadow-sm">
                        <i class="bi bi-file-earmark-pdf me-2"></i> Exportar PDF
                    </button>
                </form>
                <form id="publicLinkForm" method="post" asp-page-handler="GeneratePublicLinkJson" asp-route-id="@Model.Budget.Id" class="d-none">
                    @Html.AntiForgeryToken()
                </form>
                <button id="btnPublicLink" type="button" class="btn btn-outline-primary rounded-pill px-3 shadow-sm">
                    <i class="bi bi-link-45deg me-2"></i> Link Público
                </button>
                @if (!string.IsNullOrEmpty(Model.Budget.WhatsAppLink))
                {
                    <a href="@Model.Budget.WhatsAppLink" target="_blank" class="btn btn-success rounded-pill px-3 shadow-sm">
                        <i class="bi bi-whatsapp me-2"></i> WhatsApp
                    </a>
                }
                <a asp-page="Edit" asp-route-id="@Model.Budget.Id" class="btn btn-primary rounded-pill px-3 shadow-sm">
                    <i class="bi bi-pencil me-2"></i> Editar
                </a>
            </div>
        </div>

        <div id="publicLinkAlert" class="alert alert-success border-0 shadow-sm d-none" role="alert">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                <div class="fw-semibold">Link público copiado.</div>
                <div class="d-flex gap-2">
                    <a id="publicLinkOpen" href="#" target="_blank" class="btn btn-sm btn-outline-success rounded-pill px-3">Abrir</a>
                    <button id="publicLinkCopyAgain" type="button" class="btn btn-sm btn-outline-dark rounded-pill px-3">Copiar novamente</button>
                </div>
            </div>
            <div class="mt-2">
                <input id="publicLinkInput" class="form-control" readonly />
            </div>
        </div>

        <div class="card shadow-lg border-0 overflow-hidden">
            <div class="card-body p-5">
                <!-- Header -->
                <div class="d-flex justify-content-between border-bottom pb-4 mb-4">
                    <div>
                        <div class="bg-primary text-white rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width: 48px; height: 48px;">
                            <i class="bi bi-calculator-fill fs-4"></i>
                        </div>
                        <h3 class="fw-bold">@Model.Budget.Title</h3>
                        <p class="text-muted mb-0">Criado em @DateTime.Now.ToShortDateString()</p>
                    </div>
                    <div class="text-end">
                        <span class="badge rounded-pill px-3 py-2 text-uppercase mb-2
                            @(Model.Budget.Status.ToString() == "Paid" ? "bg-success" :
                              Model.Budget.Status.ToString() == "Approved" ? "bg-primary" :
                              Model.Budget.Status.ToString() == "Rejected" ? "bg-danger" :
                              Model.Budget.Status.ToString() == "Sent" ? "bg-warning text-dark" :
                              "bg-secondary")">
                            @Model.Budget.Status
                        </span>
                        <div class="text-muted small">Válido até</div>
                        <div class="fw-bold">@Model.Budget.ExpirationDate.ToShortDateString()</div>
                    </div>
                </div>

                <!-- Info Grid -->
                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <h6 class="text-uppercase text-muted small fw-bold mb-3">Cliente</h6>
                        <div class="d-flex align-items-center p-3 bg-light rounded-3">
                            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 48px; height: 48px;">
                                <i class="bi bi-person-fill text-primary"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">@Model.Budget.CustomerName</div>
                                <div class="small text-muted">Cliente Cadastrado</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-uppercase text-muted small fw-bold mb-3">Detalhes</h6>
                        <div class="p-3 bg-light rounded-3 h-100">
                            <p class="mb-0 text-muted">@Model.Budget.Description</p>
                        </div>
                    </div>
                </div>

                <!-- Items Table -->
                <div class="mb-5">
                    <h6 class="text-uppercase text-muted small fw-bold mb-3">Itens do Serviço</h6>
                    <div class="table-responsive rounded-3 border">
                        <table class="table table-borderless mb-0 align-middle">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-uppercase text-muted small fw-bold">Item</th>
                                    <th class="py-3 text-uppercase text-muted small fw-bold">Descrição</th>
                                    <th class="py-3 text-center text-uppercase text-muted small fw-bold">Qtd</th>
                                    <th class="py-3 text-end text-uppercase text-muted small fw-bold">Valor Unit.</th>
                                    <th class="py-3 pe-4 text-end text-uppercase text-muted small fw-bold">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Budget.Items != null)
                                {
                                    @foreach (var item in Model.Budget.Items)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-medium">@item.Name</td>
                                            <td class="text-muted small">@item.Description</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">@item.UnitPrice.ToString("C2")</td>
                                            <td class="pe-4 text-end fw-bold">@item.TotalPrice.ToString("C2")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-4 mb-5">
                    <h6 class="text-uppercase text-muted small fw-bold mb-3">Pagamento (Pix)</h6>
                    <div class="p-4 bg-light rounded-3">
                        @if (Model.Payment == null)
                        {
                            <p class="text-muted mb-3">Gere um Pix para este orçamento e envie para o cliente.</p>
                            <form method="post" asp-page-handler="GeneratePix" asp-route-id="@Model.Budget.Id" class="d-inline">
                                <button type="submit" class="btn btn-success rounded-pill px-4">
                                    <i class="bi bi-qr-code me-2"></i> Gerar Pix
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="d-flex flex-column flex-lg-row gap-4">
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div>
                                            <div class="fw-bold">Status: @Model.Payment.Status</div>
                                            <div class="text-muted small">Valor: @Model.Payment.Amount.ToString("C2")</div>
                                        </div>
                                        <form method="post" asp-page-handler="SyncPayment" asp-route-id="@Model.Budget.Id" class="d-inline">
                                            <button type="submit" class="btn btn-outline-primary rounded-pill px-3">
                                                <i class="bi bi-arrow-repeat me-2"></i> Sincronizar
                                            </button>
                                        </form>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(Model.Payment.TicketUrl))
                                    {
                                        <a href="@Model.Payment.TicketUrl" target="_blank" class="btn btn-outline-dark rounded-pill px-3 mb-3">
                                            <i class="bi bi-box-arrow-up-right me-2"></i> Abrir link do Pix
                                        </a>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(Model.Payment.QrCode))
                                    {
                                        <label class="form-label text-muted small fw-bold">Copia e cola</label>
                                        <div class="input-group">
                                            <input id="pixCode" class="form-control" value="@Model.Payment.QrCode" readonly />
                                            <button type="button" class="btn btn-dark" onclick="navigator.clipboard.writeText(document.getElementById('pixCode').value);">
                                                Copiar
                                            </button>
                                        </div>
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(Model.Payment.QrCodeBase64))
                                {
                                    <div class="text-center">
                                        <div class="bg-white p-3 rounded-3 shadow-sm">
                                            <img src="data:image/png;base64,@Model.Payment.QrCodeBase64" alt="QR Code Pix" style="max-width: 220px; height: auto;" />
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Footer / Totals -->
                <div class="row justify-content-end">
                    <div class="col-md-5 col-lg-4">
                        <div class="bg-light p-4 rounded-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted">Subtotal</span>
                                <span class="fw-bold">@Model.Budget.TotalAmount.ToString("C2")</span>
                            </div>
                            <hr class="my-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fs-5 fw-bold text-dark">Total Geral</span>
                                <span class="fs-4 fw-bold text-primary">@Model.Budget.TotalAmount.ToString("C2")</span>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Budget.Observations))
                {
                    <div class="mt-5 pt-4 border-top">
                        <h6 class="text-uppercase text-muted small fw-bold mb-2">Observações</h6>
                        <p class="text-muted fst-italic mb-0">@Model.Budget.Observations</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var btn = document.getElementById('btnPublicLink');
        if (!btn) return;

        var form = document.getElementById('publicLinkForm');
        var alertBox = document.getElementById('publicLinkAlert');
        var input = document.getElementById('publicLinkInput');
        var open = document.getElementById('publicLinkOpen');
        var copyAgain = document.getElementById('publicLinkCopyAgain');

        function showAlert(url, copied) {
            input.value = url;
            open.href = url;
            alertBox.classList.remove('d-none');
            alertBox.classList.toggle('alert-success', copied === true);
            alertBox.classList.toggle('alert-warning', copied !== true);
            alertBox.querySelector('.fw-semibold').textContent = copied === true ? 'Link público copiado.' : 'Link gerado. Copie manualmente se necessário.';
        }

        async function copyText(text) {
            try {
                await navigator.clipboard.writeText(text);
                return true;
            } catch (e) {
                return false;
            }
        }

        btn.addEventListener('click', async function () {
            btn.disabled = true;
            try {
                var tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
                var token = tokenInput ? tokenInput.value : '';

                var res = await fetch(form.action, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    credentials: 'same-origin'
                });
                var json = await res.json();
                if (!json || json.ok !== true || !json.url) {
                    alertBox.classList.remove('d-none');
                    alertBox.classList.remove('alert-success');
                    alertBox.classList.add('alert-danger');
                    alertBox.querySelector('.fw-semibold').textContent = (json && json.message) ? json.message : 'Erro ao gerar link público.';
                    return;
                }

                var copied = await copyText(json.url);
                showAlert(json.url, copied);
            } finally {
                btn.disabled = false;
            }
        });

        copyAgain.addEventListener('click', async function () {
            var ok = await copyText(input.value);
            showAlert(input.value, ok);
        });
    })();
</script>
