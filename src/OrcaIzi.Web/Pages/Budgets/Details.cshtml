@page "{id:Guid}"
@model OrcaIzi.Web.Pages.Budgets.DetailsModel
@{
    ViewData["Title"] = "Detalhes do Orçamento";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
            <div class="mb-3 mb-md-0">
                <h2 class="fw-bold mb-1">Detalhes do Orçamento</h2>
                <p class="text-muted mb-0">Visualize as informações completas</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-page="Index" class="btn btn-light rounded-pill px-3">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
                <form method="post" asp-page-handler="ExportPdf" asp-route-id="@Model.Budget.Id" class="d-inline">
                    <button type="submit" class="btn btn-danger rounded-pill px-3 shadow-sm">
                        <i class="bi bi-file-earmark-pdf me-2"></i> Exportar PDF
                    </button>
                </form>
                <a asp-page="Edit" asp-route-id="@Model.Budget.Id" class="btn btn-primary rounded-pill px-3 shadow-sm">
                    <i class="bi bi-pencil me-2"></i> Editar
                </a>
            </div>
        </div>

        <div class="card shadow-lg border-0 overflow-hidden">
            <div class="card-body p-5">
                <!-- Header -->
                <div class="d-flex justify-content-between border-bottom pb-4 mb-4">
                    <div>
                        <div class="bg-primary text-white rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width: 48px; height: 48px;">
                            <i class="bi bi-calculator-fill fs-4"></i>
                        </div>
                        <h3 class="fw-bold">@Model.Budget.Title</h3>
                        <p class="text-muted mb-0">Criado em @DateTime.Now.ToShortDateString()</p>
                    </div>
                    <div class="text-end">
                        <span class="badge rounded-pill px-3 py-2 text-uppercase mb-2
                            @(Model.Budget.Status.ToString() == "Approved" ? "bg-success" : 
                              Model.Budget.Status.ToString() == "Pending" ? "bg-warning text-dark" : "bg-secondary")">
                            @Model.Budget.Status
                        </span>
                        <div class="text-muted small">Válido até</div>
                        <div class="fw-bold">@Model.Budget.ExpirationDate.ToShortDateString()</div>
                    </div>
                </div>

                <!-- Info Grid -->
                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <h6 class="text-uppercase text-muted small fw-bold mb-3">Cliente</h6>
                        <div class="d-flex align-items-center p-3 bg-light rounded-3">
                            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 48px; height: 48px;">
                                <i class="bi bi-person-fill text-primary"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">@Model.Budget.CustomerName</div>
                                <div class="small text-muted">Cliente Cadastrado</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-uppercase text-muted small fw-bold mb-3">Detalhes</h6>
                        <div class="p-3 bg-light rounded-3 h-100">
                            <p class="mb-0 text-muted">@Model.Budget.Description</p>
                        </div>
                    </div>
                </div>

                <!-- Items Table -->
                <div class="mb-5">
                    <h6 class="text-uppercase text-muted small fw-bold mb-3">Itens do Serviço</h6>
                    <div class="table-responsive rounded-3 border">
                        <table class="table table-borderless mb-0 align-middle">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-uppercase text-muted small fw-bold">Item</th>
                                    <th class="py-3 text-uppercase text-muted small fw-bold">Descrição</th>
                                    <th class="py-3 text-center text-uppercase text-muted small fw-bold">Qtd</th>
                                    <th class="py-3 text-end text-uppercase text-muted small fw-bold">Valor Unit.</th>
                                    <th class="py-3 pe-4 text-end text-uppercase text-muted small fw-bold">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Budget.Items != null)
                                {
                                    @foreach (var item in Model.Budget.Items)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-medium">@item.Name</td>
                                            <td class="text-muted small">@item.Description</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">@item.UnitPrice.ToString("C2")</td>
                                            <td class="pe-4 text-end fw-bold">@item.TotalPrice.ToString("C2")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Footer / Totals -->
                <div class="row justify-content-end">
                    <div class="col-md-5 col-lg-4">
                        <div class="bg-light p-4 rounded-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted">Subtotal</span>
                                <span class="fw-bold">@Model.Budget.TotalAmount.ToString("C2")</span>
                            </div>
                            <hr class="my-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fs-5 fw-bold text-dark">Total Geral</span>
                                <span class="fs-4 fw-bold text-primary">@Model.Budget.TotalAmount.ToString("C2")</span>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Budget.Observations))
                {
                    <div class="mt-5 pt-4 border-top">
                        <h6 class="text-uppercase text-muted small fw-bold mb-2">Observações</h6>
                        <p class="text-muted fst-italic mb-0">@Model.Budget.Observations</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
