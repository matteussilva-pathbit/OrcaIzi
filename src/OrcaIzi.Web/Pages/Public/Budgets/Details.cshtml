@page "/Public/Budgets/{shareId:guid}"
@model OrcaIzi.Web.Pages.Public.Budgets.DetailsModel
@{
    ViewData["Title"] = "Orçamento";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model.Budget == null)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    <h3 class="fw-bold mb-2">Orçamento não encontrado</h3>
                    <p class="text-muted mb-0">O link pode ter expirado ou sido desativado.</p>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
                <div class="mb-3 mb-md-0">
                    <h2 class="fw-bold mb-1">@Model.Budget.Title</h2>
                    <p class="text-muted mb-0">@Model.Budget.CompanyName</p>
                </div>
                <div class="d-flex gap-2">
                    @if (!string.IsNullOrWhiteSpace(Model.Budget.PaymentLink))
                    {
                        <a href="@Model.Budget.PaymentLink" target="_blank" class="btn btn-success rounded-pill px-3 shadow-sm">
                            <i class="bi bi-qr-code me-2"></i> Pagar com Pix
                        </a>
                    }
                    <a href="@Url.Page("/Public/Budgets/Details", new { shareId = Model.ShareId })" class="btn btn-light rounded-pill px-3">
                        <i class="bi bi-arrow-clockwise me-2"></i> Atualizar
                    </a>
                </div>
            </div>

            <div class="card shadow-lg border-0 overflow-hidden mb-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between border-bottom pb-4 mb-4">
                        <div>
                            <h5 class="text-muted mb-2">Cliente</h5>
                            <div class="fw-bold">@Model.Budget.CustomerName</div>
                            @if (!string.IsNullOrWhiteSpace(Model.Budget.CustomerDocument))
                            {
                                <div class="text-muted small">@Model.Budget.CustomerDocument</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Budget.CustomerEmail))
                            {
                                <div class="text-muted small">@Model.Budget.CustomerEmail</div>
                            }
                        </div>
                        <div class="text-end">
                            <div class="text-muted small">Validade</div>
                            <div class="fw-bold">@Model.Budget.ExpirationDate.ToShortDateString()</div>
                            <div class="mt-2">
                                <span class="badge rounded-pill px-3 py-2 text-uppercase
                                    @(Model.Budget.Status == "Paid" ? "bg-success" :
                                      Model.Budget.Status == "Approved" ? "bg-primary" :
                                      Model.Budget.Status == "Rejected" ? "bg-danger" :
                                      Model.Budget.Status == "Sent" ? "bg-warning text-dark" : "bg-secondary")">
                                    @Model.Budget.Status
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted small fw-bold mb-2">Descrição</h6>
                        <div class="p-3 bg-light rounded-3">
                            <div class="text-muted">@Model.Budget.Description</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-uppercase text-muted small fw-bold mb-2">Itens</h6>
                        <div class="table-responsive rounded-3 border">
                            <table class="table table-borderless mb-0 align-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 py-3">Item</th>
                                        <th class="py-3">Descrição</th>
                                        <th class="py-3 text-center">Qtd</th>
                                        <th class="py-3 text-end">Unit.</th>
                                        <th class="py-3 pe-4 text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Budget.Items)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-medium">@item.Name</td>
                                            <td class="text-muted small">@item.Description</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">@item.UnitPrice.ToString("C2")</td>
                                            <td class="pe-4 text-end fw-bold">@item.TotalPrice.ToString("C2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row justify-content-end">
                        <div class="col-md-5 col-lg-4">
                            <div class="bg-light p-4 rounded-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-6 fw-bold text-dark">Total</span>
                                    <span class="fs-4 fw-bold text-primary">@Model.Budget.TotalAmount.ToString("C2")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Budget.Observations))
                    {
                        <div class="mt-4 pt-4 border-top">
                            <h6 class="text-uppercase text-muted small fw-bold mb-2">Observações</h6>
                            <p class="text-muted mb-0">@Model.Budget.Observations</p>
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Aprovação</h5>
                    <form method="post" class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Seu nome</label>
                            <input asp-for="Decision.Name" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Documento (opcional)</label>
                            <input asp-for="Decision.Document" class="form-control" />
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" asp-page-handler="Approve" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-check2-circle me-2"></i> Aprovar
                            </button>
                            <button type="submit" asp-page-handler="Reject" class="btn btn-outline-danger rounded-pill px-4">
                                <i class="bi bi-x-circle me-2"></i> Rejeitar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

