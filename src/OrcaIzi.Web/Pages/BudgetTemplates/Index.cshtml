@page
@model OrcaIzi.Web.Pages.BudgetTemplates.IndexModel
@{
    ViewData["Title"] = "Templates de Orçamento";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1">Templates</h1>
        <p class="text-muted mb-0">Crie modelos para gerar orçamentos rapidamente</p>
    </div>
    <a asp-page="Create" class="btn btn-primary rounded-pill px-4 mt-3 mt-md-0 shadow-sm">
        <i class="bi bi-plus-lg me-2"></i> Novo Template
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="post">
            <div class="row align-items-end">
                <div class="col-md-6">
                    <label class="form-label">Cliente para criar orçamento</label>
                    <select asp-for="SelectedCustomerId" asp-items="Model.Customers" class="form-select" style="background-color: #000 !important; color: #fff !important;">
                        <option value="">Selecione um cliente...</option>
                    </select>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase text-muted small fw-bold border-0">Nome</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Total</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Itens</th>
                        <th class="py-3 text-uppercase text-muted small fw-bold border-0">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Templates.Items != null && Model.Templates.Items.Any())
                    {
                        @foreach (var item in Model.Templates.Items)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="fw-bold">@item.Name</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                    {
                                        <div class="text-muted small text-truncate" style="max-width: 400px;">@item.Description</div>
                                    }
                                </td>
                                <td class="py-3">R$ @item.TotalAmount.ToString("N2")</td>
                                <td class="py-3">@item.Items.Count</td>
                                <td class="py-3">
                                    <div class="d-flex gap-2">
                                        <form method="post" asp-page-handler="CreateBudget" asp-route-id="@item.Id" class="d-inline">
                                            <input type="hidden" name="SelectedCustomerId" value="@Model.SelectedCustomerId" />
                                            <button type="submit" class="btn btn-sm btn-light text-success" title="Criar orçamento">
                                                <i class="bi bi-lightning-charge"></i>
                                            </button>
                                        </form>
                                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('Excluir este template?');">
                                            <button type="submit" class="btn btn-sm btn-light text-danger" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="py-5">
                                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                                        <i class="bi bi-layout-text-sidebar-reverse text-muted fs-2"></i>
                                    </div>
                                    <h5 class="text-muted mb-1">Nenhum template encontrado</h5>
                                    <p class="text-muted small mb-3">Crie um template para agilizar seus orçamentos.</p>
                                    <a asp-page="Create" class="btn btn-outline-primary btn-sm rounded-pill">
                                        Adicionar Template
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Templates.TotalCount > Model.PageSize)
    {
        <div class="card-footer bg-white border-top-0 py-3">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(Model.Templates.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link border-0 text-muted" asp-route-PageNumber="@(Model.Templates.PageNumber - 1)">Anterior</a>
                    </li>

                    @{
                        var totalPages = (int)Math.Ceiling((double)Model.Templates.TotalCount / Model.PageSize);
                        for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == Model.Templates.PageNumber ? "active" : "")">
                                <a class="page-link border-0 rounded-circle mx-1 @(i == Model.Templates.PageNumber ? "bg-primary text-white" : "text-muted")"
                                   style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;"
                                   asp-route-PageNumber="@i">@i</a>
                            </li>
                        }
                    }

                    <li class="page-item @(Model.Templates.PageNumber == totalPages ? "disabled" : "")">
                        <a class="page-link border-0 text-muted" asp-route-PageNumber="@(Model.Templates.PageNumber + 1)">Próximo</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

